# Photon Spectrum project credentials (from https://app.photon.codes).
PROJECT_ID=
PROJECT_SECRET=

# Convex deployment URL — the same value as the repo-root .env CONVEX_URL.
CONVEX_URL=https://your-project-123.convex.cloud

# REQUIRED allowlist: only accept commands from these iMessage handles
# (comma-separated phone numbers / emails). The number is public, so the gateway
# fails closed — an empty list ignores everyone.
SPECTRUM_ALLOWED_SENDERS=+15551234567,you@example.com
