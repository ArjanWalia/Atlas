# ============================================================================
# Atlas configuration. Copy this file to `.env` and fill in your key:
#     cp .env.example .env
# Every line except ANTHROPIC_API_KEY is optional — sensible defaults are shown.
# ============================================================================

# REQUIRED — your Anthropic API key. Powers BOTH Claude agents:
#   1. the formatting agent (turns your speech into a clean Cursor prompt)
#   2. the summary agent    (turns Cursor's output into a spoken reply)
# Both run on Claude Opus 4.8.  Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...



# ---------------------------------------------------------------------------
# Claude agents (optional)
# ---------------------------------------------------------------------------
ATLAS_MODEL=claude-opus-4-8
ATLAS_FORMAT_THINKING=1     # 1 = let Claude think before formatting (higher quality, slower)
ATLAS_EFFORT=max         # low | medium | high | max  (only used when thinking is on)

# ---------------------------------------------------------------------------
# "Voice Cursor" — the Cursor CLI agent that does the real work.
# Install it from https://cursor.com/cli and authenticate once:
#     cursor-agent login        (or set CURSOR_API_KEY below)
# To run Cursor on Opus 4.8: add your Anthropic key inside the Cursor app and
# pick Opus 4.8 as the model, OR set ATLAS_CURSOR_MODEL to the exact id your
# Cursor exposes for Opus 4.8.
# ---------------------------------------------------------------------------
ATLAS_CURSOR_COMMAND=cursor-agent
ATLAS_CURSOR_MODEL=
CURSOR_API_KEY=
ATLAS_WORKDIR=
ATLAS_CURSOR_FORCE=
ATLAS_CURSOR_TIMEOUT=600   # seconds to wait for Cursor

# ---------------------------------------------------------------------------
# Voice input (speech-to-text)
# ---------------------------------------------------------------------------
STT_BACKEND=google         # google (no setup, needs internet) | whisper (offline, private)
ATLAS_WHISPER_MODEL=base.en
ATLAS_PAUSE_THRESHOLD=0.8  # seconds of silence that ends a phrase
ATLAS_PHRASE_TIME_LIMIT=30 # max seconds for one spoken command
ATLAS_ENERGY_THRESHOLD=
ATLAS_MIC_INDEX=
# ---------------------------------------------------------------------------
# Voice output
# ---------------------------------------------------------------------------
ATLAS_TTS_BACKEND=elevenlabs     # elevenlabs | say
ELEVENLABS_API_KEY=              # get one at https://elevenlabs.io (leave blank to use macOS `say`)
ELEVENLABS_MODEL=eleven_flash_v2_5 # efficient low-latency ElevenLabs TTS model
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM # Rachel
ATLAS_TTS_VOICE=Daniel           # e.g. Samantha, Daniel, Alex   (run `say -v ?` to list)
ATLAS_TTS_RATE=150            # words per minute, e.g. 190
ATLAS_SPEAK_PREFACE=1      # speak a short "Working on it" once your command is understood
